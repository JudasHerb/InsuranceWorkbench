{
  "routes": [
    {
      "route": "/api/*",
      "rewrite": "__BACKEND_URL__/api/*"
    },
    {
      "route": "/hubs/*",
      "rewrite": "__BACKEND_URL__/hubs/*"
    },
    {
      "route": "/*",
      "serve": "/index.html",
      "statusCode": 200
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/hubs/*", "/*.{css,js,ico,png,svg,woff2}"]
  },
  "globalHeaders": {
    "Cache-Control": "no-store"
  }
}
